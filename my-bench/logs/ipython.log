    email = "testlimited@example.com"
    if not frappe.db.exists("User", email):
        user = frappe.get_doc({
            "doctype": "User",
            "email": email,
            "first_name": "Test",
            "last_name": "Limited",
            "send_welcome_email": 0,
        })
        user.insert(ignore_permissions=True)
        
